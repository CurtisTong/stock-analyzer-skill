{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StockFiveLayer",
  "description": "/stock full 五层分析的完整输出契约",
  "type": "object",
  "required": ["code", "name", "fundamental", "valuation", "technical", "sentiment", "position_plan", "market_anchor"],
  "properties": {
    "code": {"type": "string", "pattern": "^(sh|sz|SH|SZ)\\d{6}$"},
    "name": {"type": "string", "minLength": 1},
    "market_anchor": {
      "type": "object",
      "description": "市场环境锚定（v2.5.0 新增；scripts/market_anchor.py 输出）",
      "required": ["regime", "as_of"],
      "properties": {
        "as_of": {"type": "string", "description": "ISO8601 数据时间戳"},
        "regime": {
          "enum": ["bull", "bear", "sideways", "panic", "euphoria", "defensive", "unknown"],
          "description": "市场环境判定（来自 experts/market_detector.py，与 decide.md §二 权重表一致）"
        },
        "regime_label_zh": {"type": "string", "description": "中文 label: 牛市/熊市/震荡/冰点/亢奋/防御型"},
        "regime_confidence": {"enum": ["high", "medium", "low"], "description": "判定置信度；缺数据时降为 low"},
        "regime_reason": {"type": "string"},
        "long_weight": {"type": "number", "minimum": 0, "maximum": 1, "description": "长线权重（debate 调权用）"},
        "short_weight": {"type": "number", "minimum": 0, "maximum": 1, "description": "短线权重（debate 调权用）"},
        "index_code": {"type": "string", "description": "大盘指数代码，默认 sh000300 沪深300"},
        "index_change_pct": {"type": "number", "description": "大盘当日涨跌幅"},
        "breadth": {
          "type": "object",
          "properties": {
            "up_count": {"type": "integer"},
            "down_count": {"type": "integer"},
            "limit_up_count": {"type": "integer"},
            "limit_down_count": {"type": "integer"},
            "up_ratio": {"type": "number"},
            "advance_ratio": {"type": "number", "description": "上涨家数/总家数（detect_market_state 入参）"},
            "new_high_low_ratio": {"type": "number"},
            "margin_ratio": {"type": "number"}
          }
        },
        "sector_strength": {
          "type": ["object", "null"],
          "description": "板块 ETF 横向对比（technical 模式为 null）",
          "properties": {
            "etfs": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "code": {"type": "string"},
                  "name": {"type": "string"},
                  "category": {"enum": ["宽基", "行业", "跨境", "商品"]},
                  "change_pct": {"type": ["number", "null"]},
                  "turnover": {"type": ["number", "null"]},
                  "strength_rank": {"type": ["integer", "null"]},
                  "quadrant": {"enum": ["强势", "中性", "弱势", "数据缺失"]},
                  "data_ok": {"type": "boolean"}
                }
              }
            },
            "top": {"type": "array", "items": {"type": "string"}, "description": "强势 top3 板块 ETF code"},
            "bottom": {"type": "array", "items": {"type": "string"}, "description": "弱势 bottom3"},
            "data_quality": {"type": ["object", "null"]}
          }
        },
        "stock_sector_compare": {
          "type": ["object", "null"],
          "description": "个股 vs 板块 vs 大盘 三段式对比",
          "properties": {
            "stock_code": {"type": "string"},
            "stock_sectors": {"type": ["array", "null"], "items": {"type": "string"}, "description": "个股所属板块列表（粗粒度，来自 sector_stocks.json）"},
            "matched_etf": {"type": ["string", "null"], "description": "代理 ETF code"},
            "matched_etf_name": {"type": ["string", "null"]},
            "stock_change_pct": {"type": ["number", "null"]},
            "sector_change_pct": {"type": ["number", "null"]},
            "index_change_pct": {"type": ["number", "null"]},
            "rps_vs_sector": {"type": ["number", "null"], "description": "个股-板块涨幅差（pp）；正=跑赢，负=跑输"},
            "rps_vs_index": {"type": ["number", "null"], "description": "个股-大盘涨幅差（pp）"},
            "verdict": {"type": "string"},
            "data_quality": {
              "type": "object",
              "properties": {
                "stock_ok": {"type": "boolean"},
                "sector_ok": {"type": "boolean"},
                "index_ok": {"type": "boolean"},
                "degraded_fields": {"type": "array", "items": {"type": "string"}}
              }
            }
          }
        },
        "data_quality": {
          "type": "object",
          "required": ["degraded_fields"],
          "properties": {
            "index_ok": {"type": "boolean"},
            "index_kline_ok": {"type": "boolean"},
            "breadth_ok": {"type": "boolean"},
            "sector_ok": {"type": "boolean"},
            "multi_timeframe_ok": {"type": "boolean"},
            "macro_ok": {"type": "boolean"},
            "liquidity_ok": {"type": "boolean"},
            "emotion_phase_ok": {"type": "boolean"},
            "degraded_fields": {
              "type": "array",
              "items": {"type": "string"},
              "description": "失败的字段名（含 v2.5.0 旧 enum + v2.5.x 新增 multi_timeframe.* / liquidity.*）；空数组表示全成功"
            }
          }
        }
      }
    },
    "multi_timeframe": {
      "type": ["object", "null"],
      "description": "v2.5.x 新增：大盘多时间框架动量（MA20/60/250 + 5/20 日动量 + ATR14）",
      "properties": {
        "ma20": {"type": ["number", "null"]},
        "ma60": {"type": ["number", "null"]},
        "ma250": {"type": ["number", "null"]},
        "ma_alignment": {"enum": ["多头排列", "空头排列", "交叉震荡", "数据不足", "unknown", null]},
        "ret_5d_pct": {"type": ["number", "null"], "description": "5 日动量 (%)"},
        "ret_20d_pct": {"type": ["number", "null"], "description": "20 日动量 (%)"},
        "atr_14": {"type": ["number", "null"]},
        "vs_ma20_pct": {"type": ["number", "null"]},
        "vs_ma60_pct": {"type": ["number", "null"]},
        "vs_ma250_pct": {"type": ["number", "null"], "description": "年线偏离度"},
        "data_quality": {"type": "object"}
      }
    },
    "macro": {
      "type": ["object", "null"],
      "description": "v2.5.x 新增：宏观-估值桥（10Y 国债 / 美元 / 汇率 / VIX / 大宗）",
      "properties": {
        "treasury_10y_pct": {"type": ["number", "null"]},
        "usd_index": {"type": ["number", "null"]},
        "usd_cny": {"type": ["number", "null"]},
        "vix": {"type": ["number", "null"]},
        "gold_usd_oz": {"type": ["number", "null"]},
        "brent_oil_usd": {"type": ["number", "null"]},
        "wti_oil_usd": {"type": ["number", "null"]},
        "lithium_carbonate_cny_t": {"type": ["number", "null"]}
      }
    },
    "leverage": {
      "type": ["object", "null"],
      "description": "v2.5.x 新增：杠杆-反身性（两融 + 期货基差）",
      "properties": {
        "margin_balance_total_yi": {"type": ["number", "null"], "description": "两市汇总融资融券余额（亿元）"},
        "margin_change_5d_pct": {"type": ["number", "null"]},
        "if_main_basis_pts": {"type": ["number", "null"], "description": "IF 主力基差（点）"},
        "ic_main_basis_pts": {"type": ["number", "null"]},
        "ih_main_basis_pts": {"type": ["number", "null"]}
      }
    },
    "valuation_bridge": {
      "type": ["object", "null"],
      "description": "v2.5.x 新增：估值桥（ERP = 1/PE - 10Y 国债）",
      "properties": {
        "erp_sh300_pct": {"type": ["number", "null"]}
      }
    },
    "liquidity_volatility": {
      "type": ["object", "null"],
      "description": "v2.5.x 新增：流动性 + 波动率",
      "properties": {
        "sh300_atr_14": {"type": ["number", "null"]},
        "sh300_annualized_vol_pct": {"type": ["number", "null"], "description": "沪深 300 60 日年化波动率 (%)"},
        "stock_avg_amount_20d_yi": {"type": ["number", "null"], "description": "个股 20 日均成交额（亿元）"},
        "stock_liquidity_ratio_pct": {"type": ["number", "null"], "description": "日均成交额/流通市值 (%)"},
        "stock_amount_source": {"type": ["string", "null"], "description": "成交额来源：amount | volume*close(估算)"},
        "data_quality": {"type": "object"}
      }
    },
    "emotion_phase": {
      "type": ["string", "null"],
      "enum": ["主升", "退潮", "震荡", "冰点", "unknown", null],
      "description": "v2.5.x 新增：情绪周期阶段（来自 market_breadth.get_market_state）"
    },
    "industry_beta": {
      "type": ["object", "null"],
      "description": "v2.6.0 新增：个股 beta 系数（动态基准指数 + 60 日窗口手写 OLS）",
      "properties": {
        "stock_code": {"type": "string"},
        "index_code": {"type": "string", "description": "sh000300 / sh000905 / sh000852（按市值动态选）"},
        "index_selection": {"type": "string"},
        "beta": {"type": ["number", "null"], "description": "1.0=与市场同向，>1 高弹性，<1 防御"},
        "alpha": {"type": ["number", "null"], "description": "日度超额收益"},
        "alpha_annual": {"type": ["number", "null"], "description": "年化 alpha（× 252）"},
        "r_squared": {"type": ["number", "null"], "description": "拟合优度 [0,1]"},
        "volatility_pct": {"type": ["number", "null"], "description": "个股 60 日年化波动率 (%)"},
        "window": {"type": "integer"},
        "n_observations": {"type": "integer"},
        "interpretation": {"type": ["string", "null"]},
        "data_quality": {"type": "object"}
      }
    },
    "portfolio_correlation": {
      "type": ["object", "null"],
      "description": "v2.6.0 新增：组合相关性矩阵 + 个股 vs 持仓组合（与 /portfolio skill 联动）",
      "properties": {
        "portfolio_empty": {"type": "boolean", "description": "true=无持仓，matrix/vs_portfolio 为 null"},
        "portfolio_codes": {"type": ["array", "null"], "items": {"type": "string"}},
        "matrix": {
          "type": ["object", "null"],
          "description": "{code: {code: corr}} 嵌套 dict；缺失 K 线的代码 corr=null",
          "additionalProperties": {"type": "object"}
        },
        "avg_pairwise_corr": {"type": ["number", "null"], "description": "持仓两两相关性均值；>0.7 高风险"},
        "high_corr_pairs": {
          "type": "array",
          "items": {"type": "array"},
          "description": "[[code_a, code_b, corr], ...] 高相关对（>=0.7）"
        },
        "vs_portfolio": {
          "type": ["object", "null"],
          "properties": {
            "stock_code": {"type": "string"},
            "vs_portfolio_avg_corr": {"type": ["number", "null"]},
            "diversification_benefit": {"enum": ["高", "中", "低", "unknown", null]},
            "n_portfolio_codes": {"type": "integer"},
            "window": {"type": "integer"}
          }
        },
        "interpretation": {"type": ["string", "null"]},
        "data_quality": {"type": "object"}
      }
    },
    "fundamental": {
      "type": "object",
      "required": ["rating"],
      "properties": {
        "rating": {"enum": ["A", "B", "C", "D"], "description": "基本面评级"},
        "roe": {"type": "number", "description": "ROE (%)"},
        "revenue_growth": {"type": "number"},
        "fcf": {"type": "number", "description": "自由现金流"},
        "debt_ratio": {"type": "number", "description": "资产负债率 (%)"}
      }
    },
    "valuation": {
      "type": "object",
      "required": ["view"],
      "properties": {
        "view": {"enum": ["低估", "合理", "偏高", "高估", "泡沫"]},
        "pe_pct": {"type": "number", "minimum": 0, "maximum": 100, "description": "PE 行业分位"},
        "pb": {"type": "number"},
        "peg": {"type": "number"}
      }
    },
    "technical": {"$ref": "./technical.schema.json"},
    "sentiment": {"type": "string", "description": "情绪定性描述"},
    "position_plan": {
      "type": "object",
      "required": ["direction", "position_pct"],
      "properties": {
        "direction": {"enum": ["强烈看多", "看多", "中性", "看空", "强烈看空"]},
        "position_pct": {"type": "number", "minimum": 0, "maximum": 100},
        "staged": {"type": "boolean", "description": "是否分步建仓"}
      }
    }
  }
}
